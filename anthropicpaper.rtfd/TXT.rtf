\f5\fs28 \cf6 \cb10 check_points = min(10, len(l))\cb1 \
\cb10 for i in range(check_points):\cb1 \
\cb10 \'a0 \'a0 if l[i] != l[0] + i * diff:\cb1 \
\cb10 \'a0 \'a0 \'a0 \'a0 is_arithmetic = False\cb1 \
